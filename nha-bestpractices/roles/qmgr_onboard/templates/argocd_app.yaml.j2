{#
What it is:
  ArgoCD Application manifest for one queue manager regional overlay.
Purpose:
  Lets qmgr onboarding create the GitOps Application that points ArgoCD at
  queue_managers/<env>/<qmgr>/overlays/<region>.
Variables coming from:
  qmgr onboarding facts: qmgr_name, current_region, namespace,
  qmgr_rel_path, git_repo_url, target_branch, instance_type.
  global_vars: argocd_namespace, argocd_project, mq_environment.
Produces:
  One ArgoCD Application YAML file for the selected queue manager and region.
  Shared target repos may keep these under an environment subdirectory.
#}
---
# ArgoCD Application - deploys {{ qmgr_name }} to {{ current_region }} region
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: {{ qmgr_name }}-{{ current_region }}
  namespace: {{ argocd_namespace }}
  labels:
    app.kubernetes.io/name: {{ qmgr_name }}
    app.kubernetes.io/instance: {{ qmgr_name }}-{{ current_region }}
    app.kubernetes.io/component: queue-manager
    app.kubernetes.io/managed-by: ansible-automation
    mq.ibm.com/environment: {{ mq_environment | upper }}
    mq.ibm.com/instance-type: {{ instance_type }}
    mq.ibm.com/region: {{ current_region }}
  finalizers:
    - resources-finalizer.argocd.argoproj.io
spec:
  project: {{ argocd_project }}
  source:
    repoURL: {{ git_repo_url }}
    targetRevision: {{ target_branch }}
    path: {{ qmgr_rel_path }}/overlays/{{ current_region }}
  destination:
    server: https://kubernetes.default.svc
    namespace: {{ namespace }}
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - RespectIgnoreDifferences=true
  ignoreDifferences:
    - kind: Secret
      jsonPointers:
        - /data
        - /metadata/annotations
        - /metadata/labels
