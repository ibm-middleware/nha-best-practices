---
# Overlay kustomization — one per region
# Generated by Ansible for region: {{ current_region }}
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization
namespace: {{ namespace }}
labels:
  - pairs:
      app.kubernetes.io/name: {{ qmgr_name }}
      app.kubernetes.io/managed-by: ansible-automation
resources:
  - qmgr.yaml
  - ../../certs
{% if enable_prometheus_monitor | default(true) | bool %}
  - ../../monitoring
{% endif %}
  - ../../objects
generatorOptions:
  disableNameSuffixHash: true
