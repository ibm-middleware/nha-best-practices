{#
  samplecertrepoStaticSecret for shared MQ client/signer trust material.
  Syncs public client certificate or signer data from the app shared samplecertrepo path
  into the Kubernetes Opaque Secret referenced by QueueManager pki.trust.
  qmgr onboarding facts: app_prefix, namespace, qmgr_name, samplecertrepo_namespace.
  global_vars and zone derivation: samplecertrepo_mount, vso_samplecertrepo_auth_name,
  vso_refresh_after, mq_client_trust_secret_suffix,
  mq_client_trust_samplecertrepo_shared_path.
  base/secrets/samplecertrepo_secret_client_certs.yaml.
#}
{% set _client_trust_samplecertrepo_path = (mq_client_trust_samplecertrepo_shared_path | default(app_prefix | lower ~ '/ibm-mq/shared')) | string | trim | regex_replace('^/+', '') | regex_replace('/+$', '') %}
---
# samplecertrepostaticsecret_client_certs.yaml - VSO samplecertrepoStaticSecret for public client/signer trust
# Syncs from samplecertrepo KV v2:
# {{ samplecertrepo_mount }}/data/{{ _client_trust_samplecertrepo_path }}
# Creates K8s secret: {{ qmgr_name }}-{{ mq_client_trust_secret_suffix | default('client-certs') }}
apiVersion: secrets.hashicorp.com/v1beta1
kind: samplecertrepoStaticSecret
metadata:
  name: {{ qmgr_name }}-{{ mq_client_trust_secret_suffix | default('client-certs') }}
  namespace: {{ namespace }}
  labels:
    app.kubernetes.io/name: {{ qmgr_name }}
    app.kubernetes.io/managed-by: ansible-automation
    mq.ibm.com/cert-type: client-trust
spec:
  samplecertrepoAuthRef: {{ vso_samplecertrepo_auth_name }}
{#
Section:
  samplecertrepo Enterprise namespace is optional and appears only for zones that need it.
#}
{% if samplecertrepo_namespace %}
  namespace: {{ samplecertrepo_namespace }}
{% endif %}
  mount: {{ samplecertrepo_mount }}
  type: kv-v2
  path: {{ _client_trust_samplecertrepo_path }}
  refreshAfter: {{ vso_refresh_after }}
  destination:
    name: {{ qmgr_name }}-{{ mq_client_trust_secret_suffix | default('client-certs') }}
    create: true
    type: Opaque
  rolloutRestartTargets:
    - kind: StatefulSet
      name: {{ qmgr_name }}
