{#
  Dummy IBM entitlement dockerconfig Secret.
  Satisfies MQ Operator imagePullSecrets expectations when the actual MQ image
  is pulled from the internal registry instead of IBM Container Registry.
  qmgr onboarding facts: namespace, qmgr_name.
  base/secrets/ibm_entitlement_dummy.yaml.
#}
---
# ibm_entitlement_dummy.yaml - Static dummy Secret for ibm-entitlement-key
# Since we use an internal registry ({{ mq_image_registry }}) instead of
# registry.example.lab, we don't need real IBM entitlement credentials.
# This empty dockerconfigjson Secret prevents operator warnings about
# missing imagePullSecrets without storing any real credentials.
apiVersion: v1
kind: Secret
metadata:
  name: ibm-entitlement-key
  namespace: {{ namespace }}
  labels:
    app.kubernetes.io/name: {{ qmgr_name }}
    app.kubernetes.io/managed-by: ansible-automation
    mq.ibm.com/purpose: dummy-entitlement
type: kubernetes.io/dockerconfigjson
data:
  # Base64 of {"auths":{}} - empty credentials
  .dockerconfigjson: "eyJhdXRocyI6e319"
