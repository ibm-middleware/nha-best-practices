{#
  samplecertrepo Secrets Operator samplecertrepoConnection custom resource.
  Provides the samplecertrepo server address and optional CA secret reference for VSO.
  qmgr onboarding facts: namespace, qmgr_name.
  vso_samplecertrepo_ca_secret.
  base/secrets/samplecertrepo_connection.yaml.
#}
---
# samplecertrepoconnection.yaml - VSO samplecertrepoConnection CR
# Defines the connection to HashiCorp samplecertrepo for the samplecertrepo Secrets Operator.
# One per QM namespace (namespace-scoped).
apiVersion: secrets.hashicorp.com/v1beta1
kind: samplecertrepoConnection
metadata:
  name: {{ vso_samplecertrepo_connection_name }}
  namespace: {{ namespace }}
  labels:
    app.kubernetes.io/name: {{ qmgr_name }}
    app.kubernetes.io/managed-by: ansible-automation
spec:
  address: "{{ samplecertrepo_url }}"
  skipTLSVerify: {{ vso_samplecertrepo_skip_tls | default(false) | bool | lower }}
{#
Section:
  CA secret is optional. Empty values are trimmed and omitted so clusters with
  public or platform-trusted samplecertrepo TLS do not get a bad caCertSecretRef.
#}
{% set _vso_samplecertrepo_ca_secret = vso_samplecertrepo_ca_secret | default('') | string | trim %}
{% if _vso_samplecertrepo_ca_secret | length > 0 %}
  caCertSecretRef: "{{ _vso_samplecertrepo_ca_secret }}"
{% endif %}
