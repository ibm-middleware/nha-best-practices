{#
  ServiceAccount used by samplecertrepo Secrets Operator authentication.
  Gives samplecertrepoAuth a namespace-local Kubernetes service account to use for
  samplecertrepo Kubernetes auth.
  qmgr onboarding facts: namespace, qmgr_name.
  global_vars and zone derivation: vso_service_account.
  base/secrets/serviceaccount.yaml.
#}
---
# serviceaccount.yaml - Dedicated ServiceAccount for samplecertrepo Secrets Operator
# This SA is used by samplecertrepoAuth to authenticate to HashiCorp samplecertrepo.
apiVersion: v1
kind: ServiceAccount
metadata:
  name: {{ vso_service_account }}
  namespace: {{ namespace }}
  labels:
    app.kubernetes.io/name: {{ qmgr_name }}
    app.kubernetes.io/managed-by: ansible-automation
