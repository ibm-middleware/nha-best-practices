{#
  samplecertrepo Secrets Operator samplecertrepoAuth custom resource.
  Defines how VSO authenticates to samplecertrepo using Kubernetes auth for the queue
  manager namespace.
  qmgr onboarding facts: namespace, qmgr_name, samplecertrepo_namespace.
  global_vars and zone derivation: vso_samplecertrepo_auth_name,
  vso_samplecertrepo_connection_name, vso_kubernetes_auth_mount, vso_samplecertrepo_role,
  vso_service_account.
  base/secrets/samplecertrepo_auth.yaml.
#}
---
# samplecertrepoauth.yaml - VSO samplecertrepoAuth CR
# Authenticates the samplecertrepo Secrets Operator to samplecertrepo using Kubernetes auth method.
# The samplecertrepo namespace/mount come from qmgr onboarding's derived `_zone`,
# which is computed from `app_sys_id` against `samplecertrepo_security_zones`.
apiVersion: secrets.hashicorp.com/v1beta1
kind: samplecertrepoAuth
metadata:
  name: {{ vso_samplecertrepo_auth_name }}
  namespace: {{ namespace }}
  labels:
    app.kubernetes.io/name: {{ qmgr_name }}
    app.kubernetes.io/managed-by: ansible-automation
spec:
  samplecertrepoConnectionRef: {{ vso_samplecertrepo_connection_name }}
  method: kubernetes
  mount: {{ vso_kubernetes_auth_mount }}
{#
Section:
  samplecertrepo Enterprise namespace is optional. It is emitted only when the selected
  security zone defines one.
#}
{% if samplecertrepo_namespace %}
  namespace: {{ samplecertrepo_namespace }}
{% endif %}
  kubernetes:
    role: {{ vso_samplecertrepo_role }}
    serviceAccount: {{ vso_service_account }}
