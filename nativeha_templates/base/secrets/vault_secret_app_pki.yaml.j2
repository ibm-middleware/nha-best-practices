---
# vaultstaticsecret_app_pki.yaml — VSO VaultStaticSecret for mTLS app PKI
# Syncs from Vault KV v2:
# {{ vault_mount }}/data/{{ app_prefix | lower }}/ibm-mq/{{ mq_environment | upper }}/{{ namespace | lower }}/{{ qmgr_name_upper }}/app-pki
# Creates K8s secret: {{ qmgr_name }}-app-pki (tls.key, tls.crt, ca.crt)
# Cert-triggered restart is owned by VSO via rolloutRestartTargets.
# QueueManager spec/image/role rolling updates are owned by the MQ Operator.
apiVersion: secrets.hashicorp.com/v1beta1
kind: VaultStaticSecret
metadata:
  name: {{ qmgr_name }}-app-pki
  namespace: {{ namespace }}
  labels:
    app.kubernetes.io/name: {{ qmgr_name }}
    app.kubernetes.io/managed-by: ansible-automation
    mq.ibm.com/cert-type: app-pki
spec:
  vaultAuthRef: {{ vso_vault_auth_name }}
{% if vault_namespace %}
  namespace: {{ vault_namespace }}
{% endif %}
  mount: {{ vault_mount }}
  type: kv-v2
  path: {{ app_prefix | lower }}/ibm-mq/{{ mq_environment | upper }}/{{ namespace | lower }}/{{ qmgr_name_upper }}/app-pki
  refreshAfter: {{ vso_refresh_after }}
  destination:
    name: {{ qmgr_name }}-app-pki
    create: true
    type: kubernetes.io/tls
  rolloutRestartTargets:
    - kind: StatefulSet
      name: {{ qmgr_name }}
