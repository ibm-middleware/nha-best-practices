---
# nha-qmgr.yaml — NativeHA QueueManager CR
# Populated and deployed by Ansible automation (nativeha_templates)
# instance_type: nha
apiVersion: mq.ibm.com/v1beta1
kind: QueueManager
metadata:
  name: {{ qmgr_name }}
  namespace: {{ namespace }}
  labels:
    mq-qmgr: {{ qmgr_name }}
    app.kubernetes.io/name: {{ qmgr_name }}
    app.kubernetes.io/instance: {{ qmgr_name }}-{{ current_region }}
    app.kubernetes.io/managed-by: ansible-automation
    mq.ibm.com/environment: {{ mq_environment | upper }}
    mq.ibm.com/instance-type: nha
    mq.ibm.com/region: {{ current_region }}
spec:
  version: PLACEHOLDER_MQ_VERSION
  license:
    accept: true
    license: PLACEHOLDER_LICENSE_ID
    use: {{ license_use }}
  imagePullSecrets:
    - name: ibm-entitlement-key

  web:
    enabled: {{ web_enabled }}
    console:
      authentication:
        provider: {{ web_authentication }}
      authorization:
        provider: {{ web_authorization }}
    manualConfig:
      configMap:
        name: {{ qmgr_name }}-{{ web_configmap }}

  pki:
    keys:
      - name: default
        secret:
          secretName: "{{ qmgr_name }}-app-pki"
          items:
            - tls.key
            - tls.crt
    trust:
      - name: clientca
        secret:
          secretName: "{{ qmgr_name }}-app-pki"
          items:
            - ca.crt

  template:
    pod:
      volumes:
{% if enable_scripts_configmap | default(true) | bool and script_files | default([]) | length > 0 %}
        - name: scripts
          configMap:
            name: "{{ qmgr_name }}-utility-scripts"
            defaultMode: 0755
{% endif %}
        - name: mqsc-config
          projected:
            defaultMode: 0755
            sources:
              - configMap:
                  name: {{ qmgr_name }}-mqsc
      containers:
        - name: qmgr
          volumeMounts:
{% if enable_scripts_configmap | default(true) | bool and script_files | default([]) | length > 0 %}
            - name: scripts
              mountPath: /scripts
              readOnly: true
{% endif %}
            - name: mqsc-config
              mountPath: /mq-config
              readOnly: true
          resources:
            requests:
              cpu: "{{ qmgr_size.request_cpu }}"
              memory: "{{ qmgr_size.request_memory }}"
            limits:
              cpu: "{{ qmgr_size.limits_cpu }}"
              memory: "{{ qmgr_size.limits_memory }}"
      nodeSelector:
        {{ node_selector_key }}: "{{ node_selector_value }}"
      tolerations:
        - key: {{ node_selector_key }}
          operator: Equal
          value: "{{ node_selector_value }}"
          effect: NoSchedule
      affinity:
        podAntiAffinity:
          requiredDuringSchedulingIgnoredDuringExecution:
            - topologyKey: topology.kubernetes.io/zone
              labelSelector:
                matchLabels:
                  mq-qmgr: {{ qmgr_name }}
          preferredDuringSchedulingIgnoredDuringExecution:
            - weight: 100
              podAffinityTerm:
                topologyKey: topology.kubernetes.io/hostname
                labelSelector:
                  matchLabels:
                    mq-qmgr: {{ qmgr_name }}

  queueManager:
    name: {{ qmgr_name_upper }}
    image: PLACEHOLDER_MQ_IMAGE
    mqsc:
      - configMap:
          name: {{ qmgr_name }}-mqsc
          items:
{% for file in mqsc_files %}
            - {{ file }}
{% endfor %}
    ini:
      - configMap:
          name: "{{ qmgr_name }}-ini"
          items:
{% for file in ini_files %}
            - {{ file }}
{% endfor %}
    availability:
      type: NativeHA
      tls:
        secretName: "{{ qmgr_name }}-nha-tls"
    metrics:
      enabled: {{ enable_metrics | default(true) | bool | lower }}
      tls:
        provider: openshift
    readinessProbe:
      initialDelaySeconds: 30
      periodSeconds: 10
      timeoutSeconds: 5
      failureThreshold: 3
      successThreshold: 1
    recoveryLogs:
      logFilePages: {{ qmgr_size.log_file_pages | default(32768) }}
    storage:
      queueManager:
        type: persistent-claim
        class: {{ storage_class_name }}
        size: "{{ qmgr_size.qmgr_storage }}"
      recoveryLogs:
        type: persistent-claim
        enabled: true
        class: {{ storage_class_name }}
        size: "{{ qmgr_size.log_storage }}"
