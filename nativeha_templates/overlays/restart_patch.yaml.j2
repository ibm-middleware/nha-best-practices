{#
  Regional JSON 6902 patch for an intentional QueueManager restart.
  Changes spec.annotations, which the MQ Operator exposes as pass-through pod
  annotations, so the operator reconciles through its managed rollout path.
  qmgr onboarding or qmgr_restart role: qmgr_restart_at, qmgr_restart_reason,
  qmgr_restart_requested_by.
  overlays/<region>/<region_label>-patch-restart.yaml.
#}
---
- op: add
  path: /spec/annotations/{{ restart_annotation_json_pointer_prefix }}~1restart-at
  value: "{{ qmgr_restart_at | default('initial') }}"
- op: add
  path: /spec/annotations/{{ restart_annotation_json_pointer_prefix }}~1restart-reason
  value: "{{ qmgr_restart_reason | default('onboarded') }}"
- op: add
  path: /spec/annotations/{{ restart_annotation_json_pointer_prefix }}~1restart-requested-by
  value: "{{ qmgr_restart_requested_by | default('ansible-automation') }}"
