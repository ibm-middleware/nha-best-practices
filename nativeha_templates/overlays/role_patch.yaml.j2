{#
  JSON 6902 patch for the CRR local role.
  Keeps the Day-2 role-switch write set tiny: only the local role value should
  change in this file. Regional identity and remote addresses live in the
  immutable topology patch generated during onboarding.
  qmgr onboarding and role switch facts: current_region, crr_role.
  overlays/<region>/<region_label>-patch-role.yaml.
#}
---
# {{ regions[current_region].region_label }}-patch-role.yaml
# Mutable Day-2 role patch. Do not add regional topology here.
# Managed by:

# NativeHA Group - local role
- op: replace
  path: /spec/queueManager/availability/nativeHAGroups/local/role
  value: {{ crr_role | trim }}
