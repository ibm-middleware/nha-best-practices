{#
  Kustomize nameReference configuration for IBM MQ QueueManager CR fields.
  Teaches Kustomize where generated ConfigMap names are referenced inside the
  QueueManager CR. App MQSC currently disables hash suffixes, but this keeps
  name-reference handling explicit if a future generated ConfigMap enables
  hashes.
  No runtime variables; this is static Kustomize transformer configuration.
  overlays/_shared/kustomizeconfig.yaml.
#}
---
# Lets Kustomize rewrite generated ConfigMap names inside the IBM MQ
# QueueManager CRD when needed.
nameReference:
  - kind: ConfigMap
    version: v1
    fieldSpecs:
      - group: mq.ibm.com
        version: v1beta1
        kind: QueueManager
        path: spec/queueManager/mqsc/configMap/name
      - group: mq.ibm.com
        version: v1beta1
        kind: QueueManager
        path: spec/template/pod/volumes/projected/sources/configMap/name
