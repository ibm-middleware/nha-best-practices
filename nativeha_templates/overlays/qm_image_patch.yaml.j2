{#
  JSON 6902 patch for MQ version, license ID, and container image.
  Keeps day-2 image upgrades in overlays/_shared without rewriting the base
  QueueManager CR.
  qmgr onboarding or image upgrade facts: mq_version, license_id.
  overlays/_shared/patches/qm-image-patch.yaml.
#}
---
# qm-image-patch.yaml - JSON 6902 patch for MQ version/license ID/image update
# Managed by: NativeHA_Image_Upgrade playbook (Day-2)
# Generated by: qmgr_onboard (initial onboarding)
# This patch targets ONLY version, license ID, and image fields.
# spec.license.use is decided during queue manager onboarding.
# All other QM fields remain untouched in qmgr.yaml.
- op: replace
  path: /spec/version
  value: "{{ mq_version }}"
- op: replace
  path: /spec/license/license
  value: "{{ license_id }}"
- op: replace
  path: /spec/queueManager/image
  value: "{{ mq_image_registry }}/{{ mq_image_repository }}:{{ mq_version }}"
