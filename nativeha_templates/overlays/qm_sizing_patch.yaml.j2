{#
  JSON 6902 patch for QueueManager runtime resources and storage sizing.
  Keeps Day-2 sizing changes in overlays/_shared without rewriting the base
  QueueManager CR. Regional overlays consume this same patch, so CPU, memory,
  queue-manager storage, and log storage stay consistent across every region
  for the queue manager. It also carries the MQ Operator allowVolumeExpansion
  guard so Day-2 storage growth works for queue managers onboarded before the
  base template gained that field.
  This Day-2 patch intentionally does not touch recovery log file pages.
  logFilePages remains as created/onboarded.
  qmgr onboarding or qmgr_sizing_update facts: qmgr_size.
  overlays/_shared/patches/qm-sizing-patch.yaml.
#}
---
# qm-sizing-patch.yaml - JSON 6902 patch for resource/storage sizing updates
# Managed by: NativeHA_Qmgr_Sizing_Update playbook (Day-2)
# Generated by: qmgr_onboard (initial onboarding)
# This patch intentionally excludes storageClass changes. Kubernetes PVC
# storageClassName is effectively immutable after claim creation; use a
# migration/rebuild procedure for storage-class changes.
- op: add
  path: /spec/queueManager/storage/allowVolumeExpansion
  value: {{ (allow_volume_expansion | default(true) | bool) | ternary('true', 'false') }}
- op: replace
  path: /spec/template/pod/containers/0/resources/requests/cpu
  value: "{{ qmgr_size.request_cpu }}"
- op: replace
  path: /spec/template/pod/containers/0/resources/requests/memory
  value: "{{ qmgr_size.request_memory }}"
- op: replace
  path: /spec/template/pod/containers/0/resources/limits/cpu
  value: "{{ qmgr_size.limits_cpu }}"
- op: replace
  path: /spec/template/pod/containers/0/resources/limits/memory
  value: "{{ qmgr_size.limits_memory }}"
- op: replace
  path: /spec/queueManager/storage/queueManager/size
  value: "{{ qmgr_size.qmgr_storage }}"
- op: replace
  path: /spec/queueManager/storage/recoveryLogs/size
  value: "{{ qmgr_size.log_storage }}"
