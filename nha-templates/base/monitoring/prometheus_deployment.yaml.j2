{#
What it is:
  Deployment for the MQ Prometheus exporter side workload.
Purpose:
  Runs the exporter container that scrapes MQ metrics using the generated
  prometheus_config ConfigMap.
Variables coming from:
  qmgr onboarding facts: qmgr_name, namespace.
  global_vars: prometheus_exporter_image, prometheus_metrics_port,
  prometheus_resources.
Produces:
  base/monitoring/prometheus_deployment.yaml.
#}
---
# Prometheus MQ exporter Deployment
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ qmgr_name }}-prometheus-exporter
  namespace: {{ namespace }}
  labels:
    app.kubernetes.io/name: {{ qmgr_name }}-prometheus-exporter
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: {{ qmgr_name }}-prometheus-exporter
  template:
    metadata:
      labels:
        app.kubernetes.io/name: {{ qmgr_name }}-prometheus-exporter
    spec:
      containers:
        - name: mq-prometheus-exporter
          image: '{{ prometheus_exporter_image }}'
          imagePullPolicy: IfNotPresent
          args:
            - /opt/bin/mq_prometheus
            - -f
            - /etc/mq-prometheus/mq_prometheus.yaml
          ports:
            - name: metrics
              containerPort: {{ prometheus_metrics_port }}
          volumeMounts:
            - name: {{ qmgr_name }}-prometheus-config
              mountPath: /etc/mq-prometheus
              readOnly: true
          resources:
            requests:
              cpu: "{{ prometheus_resources.requests.cpu }}"
              memory: "{{ prometheus_resources.requests.memory }}"
            limits:
              cpu: "{{ prometheus_resources.limits.cpu }}"
              memory: "{{ prometheus_resources.limits.memory }}"
          readinessProbe:
            httpGet:
              path: /metrics
              port: metrics
            initialDelaySeconds: 10
            periodSeconds: 15
          livenessProbe:
            httpGet:
              path: /metrics
              port: metrics
            initialDelaySeconds: 20
            periodSeconds: 30
      volumes:
        - name: {{ qmgr_name }}-prometheus-config
          configMap:
            name: {{ qmgr_name }}-prometheus-config
