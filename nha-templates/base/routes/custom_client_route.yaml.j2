{#
What it is:
  Optional custom OpenShift Route for external MQ client traffic.
Purpose:
  Exposes the queue manager on the company DNS name, for example
  <qmgr>.example.com, using TLS passthrough so MQ TLS terminates at MQ.
Variables coming from:
  qmgr onboarding facts: qmgr_name, namespace.
  global_vars: custom_client_dns_domain, custom_client_route_name_suffix,
  custom_client_route_target_port.
Produces:
  base/routes/custom_client_route.yaml.
#}
---
apiVersion: route.openshift.io/v1
kind: Route
metadata:
  name: {{ qmgr_name }}-{{ custom_client_route_name_suffix | default('client-custom') }}
  namespace: {{ namespace }}
  annotations:
    argocd.argoproj.io/sync-options: ServerSideApply=false
  labels:
    mq-qmgr: {{ qmgr_name }}
    app.kubernetes.io/name: {{ qmgr_name }}
    app.kubernetes.io/component: mq-client-route
    app.kubernetes.io/managed-by: ansible-automation
spec:
  host: {{ qmgr_name }}.{{ custom_client_dns_domain }}
  to:
    kind: Service
    name: {{ qmgr_name }}-ibm-mq
    weight: 100
  port:
    targetPort: {{ custom_client_route_target_port | default(1414) }}
  tls:
    termination: passthrough
    insecureEdgeTerminationPolicy: None
  wildcardPolicy: None
