{#
What it is:
  VaultStaticSecret for NativeHA inter-pod TLS material.
Purpose:
  Syncs nha-tls certificate data from Vault into the Kubernetes TLS Secret used
  by the MQ NativeHA availability section.
Variables coming from:
  qmgr onboarding facts: app_prefix, mq_environment, namespace,
  qmgr_name, qmgr_name_upper, vault_namespace.
  global_vars and zone derivation: vault_mount, vso_vault_auth_name,
  vso_refresh_after.
Produces:
  base/secrets/vault_secret_nha.yaml.
#}
---
# vaultstaticsecret_nha_tls.yaml - VSO VaultStaticSecret for NHA inter-pod TLS
# Syncs from Vault KV v2:
# {{ vault_mount }}/data/{{ app_prefix | lower }}/ibm-mq/{{ mq_environment | upper }}/{{ namespace | lower }}/{{ qmgr_name_upper }}/nha-tls
# Creates K8s secret: {{ qmgr_name }}-nha-tls
# Cert-triggered restart is owned by VSO via rolloutRestartTargets.
# QueueManager spec/image/role rolling updates are owned by the MQ Operator.
apiVersion: secrets.hashicorp.com/v1beta1
kind: VaultStaticSecret
metadata:
  name: {{ qmgr_name }}-nha-tls
  namespace: {{ namespace }}
  labels:
    app.kubernetes.io/name: {{ qmgr_name }}
    app.kubernetes.io/managed-by: ansible-automation
    mq.ibm.com/cert-type: nha-tls
spec:
  vaultAuthRef: {{ vso_vault_auth_name }}
{#
Section:
  Vault Enterprise namespace is optional and appears only for zones that need it.
#}
{% if vault_namespace %}
  namespace: {{ vault_namespace }}
{% endif %}
  mount: {{ vault_mount }}
  type: kv-v2
  path: {{ app_prefix | lower }}/ibm-mq/{{ mq_environment | upper }}/{{ namespace | lower }}/{{ qmgr_name_upper }}/nha-tls
  refreshAfter: {{ vso_refresh_after }}
  destination:
    name: {{ qmgr_name }}-nha-tls
    create: true
    type: kubernetes.io/tls
  rolloutRestartTargets:
    - kind: StatefulSet
      name: {{ qmgr_name }}
