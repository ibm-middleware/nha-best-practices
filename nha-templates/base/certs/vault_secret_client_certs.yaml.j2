{#
What it is:
  VaultStaticSecret for shared MQ client/signer trust material.
Purpose:
  Syncs public client certificate or signer data from the app shared Vault path
  into the Kubernetes Opaque Secret referenced by QueueManager pki.trust.
Variables coming from:
  qmgr onboarding facts: app_prefix, namespace, qmgr_name, vault_namespace.
  global_vars and zone derivation: vault_mount, vso_vault_auth_name,
  vso_refresh_after, mq_client_trust_secret_suffix,
  mq_client_trust_vault_shared_path.
Produces:
  base/secrets/vault_secret_client_certs.yaml.
#}
{% set _client_trust_vault_path = (mq_client_trust_vault_shared_path | default(app_prefix | lower ~ '/ibm-mq/shared')) | string | trim | regex_replace('^/+', '') | regex_replace('/+$', '') %}
---
# vaultstaticsecret_client_certs.yaml - VSO VaultStaticSecret for public client/signer trust
# Syncs from Vault KV v2:
# {{ vault_mount }}/data/{{ _client_trust_vault_path }}
# Creates K8s secret: {{ qmgr_name }}-{{ mq_client_trust_secret_suffix | default('client-certs') }}
apiVersion: secrets.hashicorp.com/v1beta1
kind: VaultStaticSecret
metadata:
  name: {{ qmgr_name }}-{{ mq_client_trust_secret_suffix | default('client-certs') }}
  namespace: {{ namespace }}
  labels:
    app.kubernetes.io/name: {{ qmgr_name }}
    app.kubernetes.io/managed-by: ansible-automation
    mq.ibm.com/cert-type: client-trust
spec:
  vaultAuthRef: {{ vso_vault_auth_name }}
{#
Section:
  Vault Enterprise namespace is optional and appears only for zones that need it.
#}
{% if vault_namespace %}
  namespace: {{ vault_namespace }}
{% endif %}
  mount: {{ vault_mount }}
  type: kv-v2
  path: {{ _client_trust_vault_path }}
  refreshAfter: {{ vso_refresh_after }}
  destination:
    name: {{ qmgr_name }}-{{ mq_client_trust_secret_suffix | default('client-certs') }}
    create: true
    type: Opaque
  rolloutRestartTargets:
    - kind: StatefulSet
      name: {{ qmgr_name }}
