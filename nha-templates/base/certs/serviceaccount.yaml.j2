{#
What it is:
  ServiceAccount used by Vault Secrets Operator authentication.
Purpose:
  Gives VaultAuth a namespace-local Kubernetes service account to use for
  Vault Kubernetes auth.
Variables coming from:
  qmgr onboarding facts: namespace, qmgr_name.
  global_vars and zone derivation: vso_service_account.
Produces:
  base/secrets/serviceaccount.yaml.
#}
---
# serviceaccount.yaml - Dedicated ServiceAccount for Vault Secrets Operator
# This SA is used by VaultAuth to authenticate to HashiCorp Vault.
apiVersion: v1
kind: ServiceAccount
metadata:
  name: {{ vso_service_account }}
  namespace: {{ namespace }}
  labels:
    app.kubernetes.io/name: {{ qmgr_name }}
    app.kubernetes.io/managed-by: ansible-automation
