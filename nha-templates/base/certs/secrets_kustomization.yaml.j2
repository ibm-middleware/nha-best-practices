{#
What it is:
  Kustomization for certificate and entitlement Secret resources.
Purpose:
  Selects Vault Secrets Operator resources only when VSO secret sync is
  explicitly enabled. OpenShift-secret mode keeps only the entitlement dummy.
Variables coming from:
  qmgr onboarding facts: instance_type.
  qmgr onboarding facts/global_vars: mq_vso_secret_sync_enabled,
  enable_vso_secret_sync.
Produces:
  base/secrets/kustomization.yaml.
#}
{% set _vso_sync_enabled = mq_vso_secret_sync_enabled | default(enable_vso_secret_sync | default(false)) | bool %}
---
# Secrets kustomization - VSO and entitlement manifests
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization
resources:
{#
Section:
  Vault backend resources. These are intentionally omitted for
  enable_vso_secret_sync=false because direct OpenShift delivery writes
  Kubernetes Secrets directly and does not need VSO CRs.
#}
{% if _vso_sync_enabled %}
  - serviceaccount.yaml
  - vault_connection.yaml
  - vault_auth.yaml
  - vault_secret_app_pki.yaml
  - vault_secret_client_certs.yaml
{#
Section:
  NativeHA and CRR need the inter-pod TLS secret. SingleInstance does not.
#}
{% if instance_type in ['nha', 'nhacrr'] %}
  - vault_secret_nha.yaml
{% endif %}
{#
Section:
  CRR needs the cross-region replication TLS secret in addition to NHA TLS.
#}
{% if instance_type == 'nhacrr' %}
  - vault_secret_nhacrr.yaml
{% endif %}
{% endif %}
  - ibm_entitlement_dummy.yaml
