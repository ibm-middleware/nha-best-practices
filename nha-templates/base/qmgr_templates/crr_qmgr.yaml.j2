{#
What it is:
  IBM MQ QueueManager custom resource template for NativeHA CRR.
Purpose:
  Provides the immutable base CR for two-region cross-region replication.
  Regional topology and local role values are left as placeholders and patched
  by regional overlays.
Variables coming from:
  qmgr onboarding facts: qmgr_name, namespace, qmgr_name_upper, qmgr_size,
  mqsc_core_files, ini_files.
  global_vars: mq_environment, license_use, web settings, storage class,
  node selector, metrics, scripts, and CRR cipher settings.
Produces:
  base/qmgr.yaml for an nhacrr queue manager.
#}
{% set _webui_enabled = mq_webui_enabled | default(enable_webui | default(web_enabled | default(false))) | bool %}
{% set _operator_metrics_enabled = mq_operator_metrics_enabled | default(enable_metrics | default(false)) | bool %}
---
# crr-qmgr.yaml - NativeHA Cross-Region Replication (CRR) QueueManager CR
# Populated and deployed by Ansible automation (nativeha_templates)
# instance_type: nhacrr
#
# IMPORTANT: Region-specific fields use PLACEHOLDER_* values. Immutable
# topology is replaced by overlays/<region>/<region_label>-patch-topology.yaml.
# Day-2 role switch changes only overlays/<region>/<region_label>-patch-role.yaml.
# See: docs/ARCHITECTURE.md
apiVersion: mq.ibm.com/v1beta1
kind: QueueManager
metadata:
  name: {{ qmgr_name }}
  namespace: {{ namespace }}
  labels:
    mq-qmgr: {{ qmgr_name }}
    app.kubernetes.io/name: {{ qmgr_name }}
    app.kubernetes.io/instance: {{ qmgr_name }}-PLACEHOLDER_REGION
    app.kubernetes.io/managed-by: ansible-automation
    mq.ibm.com/environment: {{ mq_environment | upper }}
    mq.ibm.com/instance-type: nhacrr
    mq.ibm.com/region: PLACEHOLDER_REGION
spec:
  annotations:
    {{ restart_annotation_prefix }}/restart-at: "initial"
    {{ restart_annotation_prefix }}/restart-reason: "onboarded"
    {{ restart_annotation_prefix }}/restart-requested-by: "ansible-automation"
  version: PLACEHOLDER_MQ_VERSION
  license:
    accept: true
    license: PLACEHOLDER_LICENSE_ID
    use: {{ license_use }}
  imagePullSecrets:
    - name: ibm-entitlement-key

  web:
    enabled: {{ _webui_enabled | ternary('true', 'false') }}
{% if _webui_enabled %}
    console:
      authentication:
        provider: {{ web_authentication }}
      authorization:
        provider: {{ web_authorization }}
    manualConfig:
      configMap:
        name: {{ qmgr_name }}-{{ web_configmap }}
{% endif %}

  pki:
    keys:
      - name: default
        secret:
          secretName: "{{ qmgr_name }}-app-pki"
          items:
            - tls.key
            - tls.crt
            - ca.crt
    trust:
      - name: {{ mq_client_trust_source_name | default('clientcerts') }}
        secret:
          secretName: "{{ qmgr_name }}-{{ mq_client_trust_secret_suffix | default('client-certs') }}"
          items:
            - {{ mq_client_trust_default_ca_item | default('company-ca.crt') }}

  template:
    pod:
      volumes:
{#
Section:
  Optional script ConfigMap mount. Generated only when script files exist and
  enable_scripts_configmap is true.
#}
{% if enable_scripts_configmap | default(true) | bool and script_files | default([]) | length > 0 %}
        - name: scripts
          configMap:
            name: "{{ qmgr_name }}-utility-scripts"
            defaultMode: 0755
{% endif %}
        - name: mqsc-config
          projected:
            defaultMode: 0755
            sources:
              - configMap:
                  name: {{ qmgr_name }}-mqsc-core
{% if app_mqsc_mount_in_pod | default(true) | bool and app_mqsc_groups | default([]) | length > 0 %}
        - name: mqsc-app-config
          projected:
            defaultMode: 0444
            sources:
{% for group in app_mqsc_groups | default([]) %}
              - configMap:
                  name: {{ qmgr_name }}-mqsc-{{ group.suffix }}
{% endfor %}
{% endif %}
      containers:
        - name: qmgr
          volumeMounts:
{% if enable_scripts_configmap | default(true) | bool and script_files | default([]) | length > 0 %}
            - name: scripts
              mountPath: /scripts
              readOnly: true
{% endif %}
            - name: mqsc-config
              mountPath: /mq-config
              readOnly: true
{% if app_mqsc_mount_in_pod | default(true) | bool and app_mqsc_groups | default([]) | length > 0 %}
            - name: mqsc-app-config
              mountPath: /mq-app-config
              readOnly: true
{% endif %}
          resources:
            requests:
              cpu: "{{ qmgr_size.request_cpu }}"
              memory: "{{ qmgr_size.request_memory }}"
            limits:
              cpu: "{{ qmgr_size.limits_cpu }}"
              memory: "{{ qmgr_size.limits_memory }}"
      nodeSelector:
        {{ node_selector_key }}: "{{ node_selector_value }}"
      tolerations:
        - key: {{ node_selector_key }}
          operator: Equal
          value: "{{ node_selector_value }}"
          effect: NoSchedule
      affinity:
        podAntiAffinity:
          requiredDuringSchedulingIgnoredDuringExecution:
            - topologyKey: topology.kubernetes.io/zone
              labelSelector:
                matchLabels:
                  mq-qmgr: {{ qmgr_name }}
          preferredDuringSchedulingIgnoredDuringExecution:
            - weight: 100
              podAffinityTerm:
                topologyKey: topology.kubernetes.io/hostname
                labelSelector:
                  matchLabels:
                    mq-qmgr: {{ qmgr_name }}

  queueManager:
    name: {{ qmgr_name_upper }}
    image: PLACEHOLDER_MQ_IMAGE
    mqsc:
      - configMap:
          name: {{ qmgr_name }}-mqsc-core
          items:
{#
Section:
  Core MQSC file references. qmgr onboarding discovers static files from
  nativeha_templates/base/mqsc-core.
#}
{% for file in mqsc_core_files %}
            - {{ file }}
{% endfor %}
    ini:
      - configMap:
          name: "{{ qmgr_name }}-ini"
          items:
{#
Section:
  INI file references. qmgr onboarding discovers static files from
  nativeha_templates/base/ini.
#}
{% for file in ini_files %}
            - {{ file }}
{% endfor %}
    availability:
      type: NativeHA
      tls:
        secretName: "{{ qmgr_name }}-nha-tls"
      nativeHAGroups:
        local:
          name: PLACEHOLDER_REGION
          role: PLACEHOLDER_ROLE
          tls:
            key:
              secretName: "{{ qmgr_name }}-nhacrr-tls"
            cipherSpec: {{ crr_cipher }}
        remotes:
          - name: PLACEHOLDER_REMOTE
            addresses:
              - "PLACEHOLDER_ADDRESS"
    metrics:
      enabled: {{ _operator_metrics_enabled | ternary('true', 'false') }}
{% if _operator_metrics_enabled %}
      tls:
        provider: openshift
{% endif %}
    readinessProbe:
      initialDelaySeconds: 30
      periodSeconds: 10
      timeoutSeconds: 5
      failureThreshold: 3
      successThreshold: 1
    recoveryLogs:
      logFilePages: {{ qmgr_size.log_file_pages | default(32768) }}
    storage:
      allowVolumeExpansion: {{ (allow_volume_expansion | default(true) | bool) | ternary('true', 'false') }}
      queueManager:
        type: persistent-claim
        class: {{ storage_class_name }}
        size: "{{ qmgr_size.qmgr_storage }}"
      recoveryLogs:
        type: persistent-claim
        enabled: true
        class: {{ storage_class_name }}
        size: "{{ qmgr_size.log_storage }}"
