<?xml version="1.0" encoding="UTF-8"?>
<server>
    <featureManager>
        <!-- Enables standard WebSphere Liberty basic security registry instead of the OS PAM registry -->
        <feature>appSecurity-2.0</feature>
    </featureManager>

    <!-- Define the Basic Registry for MQ Console Authentication -->
    <basicRegistry id="basic" realm="defaultRealm">
        <!-- Define local test users -->
        <user name="admin" password="password"/>
        <user name="viewer" password="password"/>

        <!-- Define groups and add members -->
        <group name="MQWebAdminGroup">
            <member name="admin"/>
        </group>
        <group name="MQWebUserGroup">
            <member name="viewer"/>
        </group>
    </basicRegistry>

    <!-- Map users and groups to the IBM MQ Console application roles -->
    <enterpriseApplication id="com.ibm.mq.console">
        <application-bnd>
            <security-role name="MQWebAdmin">
                <group name="MQWebAdminGroup"/>
            </security-role>
            <security-role name="MQWebUser">
                <group name="MQWebUserGroup"/>
            </security-role>
        </application-bnd>
    </enterpriseApplication>
</server>
